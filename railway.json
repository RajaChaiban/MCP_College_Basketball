{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "dockerfile",
    "dockerfile": "Dockerfile.railway"
  },
  "deploy": {
    "numReplicas": 1,
    "healthchecks": {
      "readiness": {
        "command": [
          "python",
          "-c",
          "import urllib.request; urllib.request.urlopen('http://localhost:8050', timeout=5)"
        ],
        "interval": 30,
        "timeout": 5,
        "successThreshold": 1,
        "failureThreshold": 3
      }
    }
  },
  "variables": {
    "GEMINI_API_KEY": {
      "description": "Google Gemini API key for AI chat",
      "value": ""
    },
    "GEMINI_MODEL": {
      "value": "gemini-2.5-flash"
    },
    "LLM_BACKEND": {
      "value": "gemini"
    },
    "CBB_DASH_PORT": {
      "value": "8050"
    },
    "CBB_DASH_HOST": {
      "value": "0.0.0.0"
    },
    "CBB_LOG_LEVEL": {
      "value": "INFO"
    },
    "CBB_DEBUG": {
      "value": "0"
    },
    "CBB_CACHE_ENABLED": {
      "value": "true"
    }
  }
}
